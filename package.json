{
	"name": "slither",
	"version": "1.5.0",
	"license": "MIT",
	"scripts": {
		"build": "rm -rf out && pnpm compile && rojo build --output place.rbxlx",
		"compile": "rbxtsc --verbose",
		"deploy:dev": "pnpm build && mantle deploy --environment canary",
		"deploy:prod": "pnpm build && mantle deploy --environment production",
		"dev": "concurrently \"rojo serve --port 34873\" \"rbxtsc -w\"",
		"output:dev": "mantle outputs --environment canary > mantle-output.json",
		"output:prod": "mantle outputs --environment production > mantle-output.json",
		"serve": "rojo serve",
		"tarmac": "tarmac sync --target roblox",
		"watch": "rbxtsc -w"
	},
	"dependencies": {
		"@flamework/components": "^1.3.1",
		"@flamework/core": "^1.3.1",
		"@flamework/networking": "^1.3.1",
		"@rbxts/bitbuffer2": "1.0.0-ts.0",
		"@rbxts/charm": "^0.10.0",
		"@rbxts/flipper": "^2.0.1",
		"@rbxts/lapis": "^0.3.8",
		"@rbxts/luau-polyfill": "^1.1.3",
		"@rbxts/object-utils": "^1.0.4",
		"@rbxts/pretty-react-hooks": "^0.6.3",
		"@rbxts/react": "^17.3.0-alpha.1",
		"@rbxts/react-charm": "^0.3.0",
		"@rbxts/react-roblox": "^17.3.0-alpha.1",
		"@rbxts/remo": "^1.5.2",
		"@rbxts/ripple": "^0.9.3",
		"@rbxts/services": "^1.5.5",
		"@rbxts/set-timeout": "^1.1.2",
		"@rbxts/t": "^3.2.1",
		"@rbxts/testez": "0.4.2-ts.0",
		"@rbxts/ui-labs": "^2.4.0",
		"@rbxts/validate-tree": "^2.0.2",
		"rbxts-transformer-flamework": "^1.3.1"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/types": "^1.0.852",
		"concurrently": "^8.2.0",
		"cross-env": "^7.0.3",
		"prettier": "^3.5.3",
		"roblox-ts": "3.0.0",
		"typescript": "^5.8.3"
	}
}
